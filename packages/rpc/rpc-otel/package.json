{
  "name": "@insler/rpc-otel",
  "description": "OpenTelemetry tracing for @insler RPC, delivered as client and host middleware, with W3C traceparent format/parse helpers.",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@insler/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "author": {
    "name": "Matt Insler",
    "email": "matt.insler@gmail.com"
  },
  "funding": "https://github.com/sponsors/mattinsler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattinsler/insler.git",
    "directory": "packages/rpc/rpc-otel"
  },
  "bugs": {
    "url": "https://github.com/mattinsler/insler/issues"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "test": "bun --conditions=@insler/source test --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "@insler/rpc": "workspace:*",
    "@opentelemetry/api": "catalog:"
  },
  "devDependencies": {
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "zod": "catalog:"
  }
}
