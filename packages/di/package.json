{
  "name": "@insler/di",
  "description": "A lightweight, type-safe dependency injection container for TypeScript",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "author": {
    "name": "Matt Insler",
    "email": "matt.insler@gmail.com"
  },
  "funding": "https://github.com/sponsors/mattinsler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattinsler/insler.git",
    "directory": "packages/di"
  },
  "bugs": {
    "url": "https://github.com/mattinsler/insler/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "debug": "catalog:",
    "object-hash": "catalog:"
  },
  "devDependencies": {
    "@types/debug": "catalog:",
    "@types/object-hash": "catalog:",
    "expect-type": "catalog:"
  }
}
