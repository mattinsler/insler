{
  "name": "@insler/rpc-host",
  "description": "The server side of @insler RPC — registers validated handlers on a transport with zod input/output validation, context extraction, error normalization, and middleware.",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "@insler/source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./dev": {
      "@insler/source": "./src/dev.ts",
      "import": "./dist/dev.mjs",
      "require": "./dist/dev.cjs"
    },
    "./test": {
      "@insler/source": "./src/test.ts",
      "import": "./dist/test.mjs",
      "require": "./dist/test.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "author": {
    "name": "Matt Insler",
    "email": "matt.insler@gmail.com"
  },
  "funding": "https://github.com/sponsors/mattinsler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattinsler/insler.git",
    "directory": "packages/rpc-host"
  },
  "bugs": {
    "url": "https://github.com/mattinsler/insler/issues"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./dev": {
        "import": "./dist/dev.mjs",
        "require": "./dist/dev.cjs"
      },
      "./test": {
        "import": "./dist/test.mjs",
        "require": "./dist/test.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "test": "bun --conditions=@insler/source test --coverage --coverage-reporter=text --coverage-reporter=lcov"
  },
  "dependencies": {
    "@insler/rpc-client": "workspace:*",
    "@insler/rpc-context": "workspace:*",
    "@insler/rpc-contract": "workspace:*",
    "@insler/rpc-transport-memory": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "expect-type": "catalog:"
  }
}
