{
  "$schema": "https://unpkg.com/oxfmt@0.52.0/configuration_schema.json",
  "ignorePatterns": [
    ".*",
    "node_modules",
    "dist",
    "build",
    "assets",
    "docs",
    "public",
    "*.md",
    "package.json",
    "!.vscode",
    "!.syncpackrc",
    "!.oxfmtrc.json",
    "!.oxlintrc.json"
  ],
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "sortImports": {},
  "sortPackageJson": false,
  "overrides": [
    {
      "files": ["*.json"],
      "options": {
        "trailingComma": "none"
      }
    }
  ]
}
