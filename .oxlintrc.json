{
  "$schema": "https://unpkg.com/oxlint@1.67.0/configuration_schema.json",
  "categories": {
    "correctness": "warn"
  },
  "ignorePatterns": ["node_modules", "dist", "build"],
  "plugins": ["import", "typescript", "unicorn"],
  "rules": {
    "import/extensions": [
      "error",
      {
        "ignorePackages": true,
        "checkTypeImports": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["packages/*/*-integration/**"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["../**"],
                "message": "Integration packages consume their subsystem's public surface only (workspace packages); a parent-relative import escaping the package would reach into sibling package sources. Non-public package subpaths are guarded by the exports map at typecheck time."
              }
            ]
          }
        ]
      }
    }
  ]
}
