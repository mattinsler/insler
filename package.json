{
  "name": "insler",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "catalog": {
    "@lcov-viewer/cli": "1.3.0",
    "@types/bun": "1.3.14",
    "@types/debug": "4.1.13",
    "@types/node": "25.9.1",
    "@types/object-hash": "3.0.6",
    "debug": "4.4.3",
    "expect-type": "1.3.0",
    "knip": "6.15.0",
    "lcov-result-merger": "6.0.0",
    "object-hash": "3.0.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "publint": "0.3.21",
    "syncpack": "15.3.1",
    "tsdown": "0.22.1",
    "typescript": "6.0.3"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "coverage-html": "lcov-viewer lcov --output ./coverage/html ./coverage/merged-lcov.info",
    "coverage-merge": "mkdir -p coverage && lcov-result-merger 'packages/*/coverage/lcov.info' ./coverage/merged-lcov.info --ignore='**/node_modules/**'",
    "fmt": "oxfmt && syncpack format",
    "fmt-check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint",
    "lint-fix": "oxlint --fix",
    "test": "bun run --parallel --workspaces --no-exit-on-error --if-present test",
    "test-report": "bun run test && bun run coverage-merge && bun run coverage-html",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@lcov-viewer/cli": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "expect-type": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "publint": "catalog:",
    "syncpack": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
