{
  "name": "insler",
  "private": true,
  "workspaces": {
    "packages": [
      "examples/*",
      "packages/*/*",
      "packages/website"
    ]
  },
  "catalog": {
    "@arethetypeswrong/core": "0.18.3",
    "@astrojs/check": "0.9.9",
    "@astrojs/starlight": "0.40.0",
    "@changesets/cli": "2.31.0",
    "@lcov-viewer/cli": "1.3.0",
    "@nats-io/transport-node": "3.4.0",
    "@opentelemetry/api": "1.9.1",
    "@types/bun": "1.3.14",
    "@types/debug": "4.1.13",
    "@types/node": "25.9.1",
    "@types/object-hash": "3.0.6",
    "astro": "6.4.6",
    "debug": "4.4.3",
    "expect-type": "1.3.0",
    "knip": "6.15.0",
    "lcov-result-merger": "6.0.0",
    "object-hash": "3.0.0",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "publint": "0.3.21",
    "std-env": "4.1.0",
    "superjson": "2.2.2",
    "syncpack": "15.3.1",
    "tsdown": "0.22.2",
    "type-fest": "5.7.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "scripts": {
    "audit": "bun audit --audit-level=high",
    "build": "tsdown",
    "ci:publish": "scripts/ci-publish.sh",
    "ci:version": "changeset version && bun update",
    "coverage-html": "lcov-viewer lcov --output ./coverage/html ./coverage/merged-lcov.info",
    "coverage-merge": "mkdir -p coverage && lcov-result-merger 'packages/*/*/coverage/lcov.info' ./coverage/merged-lcov.info --ignore='**/node_modules/**'",
    "fmt": "oxfmt && syncpack format",
    "fmt-check": "oxfmt --check",
    "knip": "knip",
    "lint": "oxlint",
    "lint-fix": "oxlint --fix",
    "publish-local": "mirror-scripts/publish-local.sh",
    "test": "bun test ./scripts && bun run --parallel --workspaces --no-exit-on-error --if-present test",
    "test-report": "bun run test && bun run coverage-merge && bun run coverage-html",
    "typecheck": "tsc --noEmit && bun run --workspaces --if-present typecheck"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@changesets/cli": "catalog:",
    "@lcov-viewer/cli": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "expect-type": "catalog:",
    "knip": "catalog:",
    "lcov-result-merger": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "publint": "catalog:",
    "syncpack": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
